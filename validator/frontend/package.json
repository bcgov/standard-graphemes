{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "format": "npx prettier . --write",
    "build": "tsc -b && vite build",
    "lint": "npx eslint .",
    "preview": "vite preview",
    "start": "npx http-server ./dist --port $PORT --proxy $PROXY",
    "test": "npx vitest"
  },
  "dependencies": {
