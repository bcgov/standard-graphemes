{
  "name": "graphemes-api",
  "version": "0.0.1",
  "description": "API for graphemes register",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start:dev": "nodemon --watch src --ext ts --exec node --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "format": "npx prettier . --write",
    "lint": "npx eslint .",
    "test": "npx vitest"
  },
  "dependencies": {
    "any-ascii": "0.3.3",
    "cors": "2.8.5",
    "dotenv": "17.2.2",
    "express": "5.1.0",
    "express-rate-limit": "8.0.1",
    "js-levenshtein-esm": "2.0.0",
    "knex": "3.1.0",
    "pg": "8.16.3",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "9.34.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/node": "24.3.0",
    "@types/supertest": "6.0.3",
    "eslint": "9.34.0",
    "globals": "16.3.0",
    "nodemon": "3.1.10",
    "prettier": "3.6.2",
    "supertest": "7.1.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.2",
    "typescript-eslint": "8.42.0",
    "vitest": "3.2.4"
  }
}
